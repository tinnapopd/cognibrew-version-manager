# Logging
LOG_LEVEL=INFO

# RabbitMQ (shared connection)
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# Face Update (cloud --> vectordb)
RABBITMQ_FACE_UPDATE_EXCHANGE_NAME=cognibrew.vectordb
RABBITMQ_FACE_UPDATE_QUEUE_NAME=cognibrew.vectordb.face_updated
RABBITMQ_FACE_UPDATE_ROUTING_KEY=face.updated

# Docker (target container to manage)
DOCKER_TARGET_LABEL=cognibrew.service=recognition
DOCKER_HEALTH_TIMEOUT_S=30
DOCKER_HEALTH_POLL_S=1

# Sync (edge-pull from cloud)
SYNC_URL=http://localhost/api/v1/sync/bundle
SYNC_DEVICE_ID=
SYNC_PAGE_SIZE=50
SYNC_SCHEDULE_TIME=01:00
SYNC_CHECK_EVERY=60
